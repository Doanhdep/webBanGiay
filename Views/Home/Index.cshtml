						<h1>Sản Phẩm Mới Nhất</h1>
						<p>Thời trang không chỉ là trang phục, mà là phong cách và cá tính của bạn.</p>
					</div>
				</div>
			</div>
			<div class="row">
				@foreach (var item in Model.LatestProducts)
				{
					<div class="col-lg-3 col-md-6">
						<div class="single-product">
							<img src="~/Image/@item.Filename" alt="@item.Title" style="width: 100%; height: 280px; object-fit: cover;">
							<div class="product-details">
								<h6>@item.Title</h6>
								<div class="rating">
									@for (int i = 1; i <= 5; i++)
									{
										if (item.Rating >= i)
										{
											<i class="fa fa-star rating-star"></i> <!-- Sao đầy -->
										}
										else if (item.Rating >= i - 0.5)
										{
											<i class="fa fa-star-half-o rating-star"></i> <!-- Nửa sao -->
										}
										else
										{
											<i class="fa fa-star-o rating-star"></i> <!-- Sao trống -->
										}
									}
								</div>
								<div class="price">
									@if (item.FinalPrice < item.Price_Default)
									{
										<h6>@String.Format(System.Globalization.CultureInfo.GetCultureInfo("vi-VN"), "{0:C0}", item.FinalPrice)</h6>
										<h6 class="l-through">@String.Format(System.Globalization.CultureInfo.GetCultureInfo("vi-VN"), "{0:C0}", item.Price_Default)</h6>
									}
									else
									{
										<h6>@String.Format(System.Globalization.CultureInfo.GetCultureInfo("vi-VN"), "{0:C0}", item.Price_Default)</h6>
									}
								</div>
								<div class="prd-bottom">
									<a href="" class="social-info">
										<span class="ti-bag"></span>
										<p class="hover-text">add to bag</p>
									</a>
									<a href="" class="social-info">
										<span class="lnr lnr-heart"></span>
										<p class="hover-text">Wishlist</p>
									</a>
									
									<a class="social-info" href="/Product/Detail?ProductId=@item.Id">
