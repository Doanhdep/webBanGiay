@foreach (var order in Model)
{
    <div class="order-card">
        <div class="shop-header">
            <span>@order.ShippingCompany</span>
            <span class="order-status">@order.OrderStatus</span>
        </div>

        @foreach (var product in order.Products)
        {
            <div class="product-info">
                <div class="product-image">
                    @if (!string.IsNullOrEmpty(product.Filename))
                    {
                        <img src="@Url.Content($"~/Image/{product.Filename}")" alt="@product.Title" style="width:100%;height:100%;object-fit:cover" />
                    }
                    else
                    {
                        <div class="no-image">No Image</div>
                    }
                </div>
                <div class="product-details">
                    <div class="product-header">
                        <div class="product-name">@product.Title</div>
                        <div class="product-actions">
                            <button class="openModal review-button" data-productPriceId="@product.Id" data-title="@product.Title">
                                Đánh giá
                            </button>

                        </div>
                    </div>

                    <div class="price-info">
                        <div class="price-section">
                            <span class="original-price">@product.Price_Default.ToString("N0")đ</span>
                            <span class="final-price">@product.FinalPrice.ToString("N0")đ</span>
                            <span class="quantity">Số lượng: @product.Quantity</span>
                        </div>
                    </div>
                </div>
            </div>
        }
        <div class="shop-footer">
            <button class="footer-button">Xem Chi Tiết</button>
            <button class="footer-button">Liên Hệ Người Bán</button>
        </div>
    </div>

    <hr />
}
