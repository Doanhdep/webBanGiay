@model List<MyStore.myDTO.Product_Price_DTO>


<div style="margin-top:40px"></div>
@if (Model != null && Model.Any())
{
<!-- Start related-product Area -->
<section class="related-product-area section_gap_bottom mt-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-6 text-center">
                <div class="section-title">
                    <h1>Ưu đãi của tuần </h1>
                    <p>
                        Khám phá phong cách của bạn với những bộ sưu tập thời trang đa dạng, từ trang phục hàng ngày đến những thiết kế tinh tế, giúp bạn tự tin tỏa sáng mọi lúc mọi nơi.
                    </p>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-9">
                <div class="row">

                        @foreach (var item in Model)
                        {
                            <div class="col-lg-4 col-md-4 col-sm-6 mb-20">
                                <div class="single-related-product d-flex">
                                    <a asp-action="Detail" asp-controller="Product" asp-route-productid="@item.ProductId">
                                        <img src="~/Image/@item.Filename" alt="@item.Title" style="width: 80px; height: 80px;" />
                                    </a>
                                    <div class="desc">
                                        <a asp-action="Detail" asp-controller="Product" asp-route-productid="@item.ProductId" class="title">
                                            @(item.Title.Length > 14 ? item.Title.Substring(0, 14) + "..." : item.Title)
                                        </a>

                                        <div class="price">
                                            <h6>
                                                @String.Format(new System.Globalization.CultureInfo("vi-VN"), "{0:N0} ₫", item.FinalPrice)
                                            </h6>
                                            @if (item.Discount > 0)
                                            {
                                                <h6 class="l-through">
                                                    @String.Format(new System.Globalization.CultureInfo("vi-VN"), "{0:N0} ₫", (item.FinalPrice * (1 + item.Discount)))

                                                </h6>
                                            }

                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    

                </div>
            </div>
            <div class="col-lg-3">
                <div class="ctg-right">
                    <a href="#" target="_blank">
                        <img class="img-fluid d-block mx-auto" src="~/img/category/c5.jpg" alt="">
                    </a>
                </div>
            </div>
        </div>
    </div>
</section>
}else
{
    <section class="related-product-area section_gap_bottom mt-5">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-lg-6 text-center">
                    <div class="section-title">
                        <h1>Ưu đãi của tuần </h1>
                        <p>
                            Khám phá phong cách của bạn với những bộ sưu tập thời trang đa dạng, từ trang phục hàng ngày đến những thiết kế tinh tế, giúp bạn tự tin tỏa sáng mọi lúc mọi nơi.
                        </p>
                    </div>
                    <div class="section-title">
                        <p class="font-weight-bold">
                            Sản phẩm  giảm giá đang được cập nhật .....
                        </p>
                    </div>
                </div>
            </div>
           
        </div>
    </section>
}
<!-- End related-product Area -->
