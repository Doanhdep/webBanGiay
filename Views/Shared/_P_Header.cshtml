	<div class="search_input" id="search_input_box">
		<div class="container">
			<form asp-controller="Product" asp-action="Search" method="get" class="d-flex justify-content-between">
				<input id="SearchText" name="query" type="search" class="form-control" placeholder="Search Here" value="@ViewBag.SearchQuery" autocomplete="off">
				<button type="submit" class="btn"></button>
				<span class="lnr lnr-cross" id="close_search" title="Close Search"></span>
			</form>
			<ul id="suggestionList" class="list-group position-absolute"></ul>
		</div>
	</div>

	<style>
		#suggestionList {
			width: calc(100% - 2px); /* Đảm bảo chiều rộng khớp với ô nhập */
			max-height: 200px;
			overflow-y: auto;
			background: white;
			border: 1px solid #ddd;
			display: none;
			position: absolute;
			z-index: 1000;
			left: 0; /* Căn gợi ý song song với ô nhập */
			top: 100%; /* Đẩy gợi ý xuống dưới ô nhập */
			border-top: none;
			border-radius: 0 0 5px 5px;
		}

			#suggestionList li {
				padding: 8px 12px;
				cursor: pointer;
				text-align: left; /* Căn chữ về bên trái */
				font-size: 14px;
			}

				#suggestionList li:hover {
					background: #f8f9fa;
				}
	</style>

</header>
<!-- Kết thúc khu vực Header -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
	$(document).ready(function () {
		$("#SearchText").on("keyup", function () {
			let query = $(this).val().trim();

			if (query.length > 1) { // Chỉ tìm khi nhập >1 ký tự
				$.ajax({
					url: "/Product/GetProductSuggestions",
					type: "GET",
					data: { query: query },
					success: function (data) {
						let suggestionList = $("#suggestionList");
						suggestionList.empty();

						if (data.length > 0) {
							data.forEach(function (item) {
								suggestionList.append(`<li class="list-group-item">${item}</li>`);
							});
							suggestionList.show();
						} else {
							suggestionList.hide();
						}
					}
				});
			} else {
				$("#suggestionList").hide();
			}
		});

		// Khi click vào gợi ý, tự động điền vào ô input
		$(document).on("click", "#suggestionList li", function () {
			$("#SearchText").val($(this).text());
			$("#suggestionList").hide();
		});

		// Ẩn gợi ý khi click ra ngoài
		$(document).click(function (e) {
			if (!$(e.target).closest("#search_input_box").length) {
				$("#suggestionList").hide();
			}
		});
	});
</script>