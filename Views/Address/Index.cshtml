@model IEnumerable<MyStore.myDTO.Address_DTO>

@{
    Layout = "_Layout";
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/linearicons.css">
    <link rel="stylesheet" href="~/css/font-awesome.min.css">
    <link rel="stylesheet" href="~/css/themify-icons.css">
    <link rel="stylesheet" href="~/css/bootstrap.css">
    <link rel="stylesheet" href="~/css/owl.carousel.css">
    <link rel="stylesheet" href="~/css/nice-select.css">
    <link rel="stylesheet" href="~/css/nouislider.min.css">
    <link rel="stylesheet" href="~/css/ion.rangeSlider.css" />
    <link rel="stylesheet" href="~/css/ion.rangeSlider.skinFlat.css" />
    <link rel="stylesheet" href="~/css/magnific-popup.css">
    <link rel="stylesheet" href="~/css/main.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
}


@await Html.PartialAsync("_P_Header")
<!-- Start Banner Area -->
<section class="banner-area organic-breadcrumb">
    <div class="container">
        <div class="breadcrumb-banner d-flex flex-wrap align-items-center justify-content-end">
            <div class="col-first">
                <h1>Login/Register</h1>
                <nav class="d-flex align-items-center">
                    <a asp-controller="Home" asp-action="Index">Home<span class="lnr lnr-arrow-right"></span></a>
                    <a asp-controller="Account" asp-action="Login">Login/Register</a>
                </nav>
            </div>
        </div>
    </div>
</section>
<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Địa chỉ của tôi</h2>
        <a data-toggle="modal" data-target="#addressModal" class="genric-btn primary font-weight-bold"
           style="font-size:15px" onclick="initMap()">Thêm địa chỉ mới</a>
    </div>

    <hr />
    <div class="list-group">
          
        @foreach (var address in Model)
        {
            <div class="list-group-item">
                <h5>@address.FullName</h5>
                <h5>@address.AddressLine</h5>
                <p>@address.City, @address.District, @address.Ward</p>
                <span class="badge @(address.IsDefault ? " badge-success" : "badge-secondary" )">
                    @(address.IsDefault ? "Default" : "")
                </span>
                <div class="mt-2">
                    <button class="btn btn-secondary btn-sm" onclick="editAddress(@address.Id)">Edit</button>
                    <button class="btn btn-danger btn-sm" onclick="deleteAddress(@address.Id)">Delete</button>
                    @if (!address.IsDefault)
                    {
                        <button class="btn btn-sm btn-default" onclick="setDefault(@address.Id)">Set as default</button>
                    }

                </div>
            </div>
        }

    </div>
</div>


<!-- Modal thêm địa chỉ  -->
<div class="modal fade" id="addressModal" tabindex="-1" role="dialog" aria-labelledby="addressModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">New Address</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">



                <form id="addAddressForm">
                    <input type="hidden" id="userId" name="UserId" value="@ViewBag.UserId">

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label for="fullName">Full Name:</label>
                            <input type="text" class="form-control" id="fullName" name="FullName" required>
                        </div>
                        <div class="form-group col-md-6">
                            <label for="phoneNumber">Phone Number:</label>
                            <input type="text" class="form-control" id="phoneNumber" name="PhoneNumber" required>
                        </div>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-4">
                            <label for="city">City:</label>
                            <select class="form-control" id="tinh" name="City" required>
                                <option value="">Select City</option>
                            </select>
                        </div>
                        <div class="form-group col-md-4">
                            <label for="district">District:</label>
                            <select class="form-control" id="quan" name="District" required>
                                <option value="">Select District</option>
                            </select>
                        </div>
                        <div class="form-group col-md-4">
                            <label for="ward">Ward:</label>
                            <select class="form-control" id="phuong" name="Ward" required>
                                <option value="">Select Ward</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="addressInput">Address Line:</label>
                        <input type="text" id="addressInput" name="AddressLine" class="form-control" placeholder="Nhập số nhà, đường, ấp..." required>
                    </div>

                    <div class="form-group">
                        <input type="checkbox" id="isDefault" name="IsDefault" value="true">
                        <label for="isDefault"> Đặt làm địa chỉ mặc định</label>
                    </div>

                    <div class="form-group">
                        <div id="map" style="width: 100%; height: 250px;"></div>
                    </div>

                    <button type="button" class="btn btn-light w-100" onclick="addCurrentLocation('add')">
                        <i class="fas fa-map-marker-alt"></i> Add Current Location
                    </button>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-danger" onclick="addAddress()">Submit</button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>


<!-- Modal Sửa Địa Chỉ -->
<div class="modal fade" id="editAddressModal" tabindex="-1" role="dialog" aria-labelledby="editAddressModalLabel" aria-hidden="true">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Update Address</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="editAddressForm">
                    <input type="hidden" id="editAddressId" name="Id">

                    <div class="form-group">
                        <label for="editFullName">Full Name:</label>
                        <input type="text" class="form-control" id="editFullName" name="FullName" required>
                    </div>
                    <div class="form-group">
                        <label for="editPhoneNumber">Phone Number:</label>
                        <input type="text" class="form-control" id="editPhoneNumber" name="PhoneNumber" required>
                    </div>

                    <div class="form-row">
                        <div class="form-group col-md-4">
                            <label for="editCity">City:</label>
                            <select class="form-control" id="editCity" name="City" required></select>
                        </div>
                        <div class="form-group col-md-4">
                            <label for="editDistrict">District:</label>
                            <select class="form-control" id="editDistrict" name="District" required></select>
                        </div>
                        <div class="form-group col-md-4">
                            <label for="editWard">Ward:</label>
                            <select class="form-control" id="editWard" name="Ward" required></select>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="editAddressLine">Address Line:</label>
                        <input type="text" id="editAddressLine" name="AddressLine" class="form-control" required>
                    </div>

                    <!-- Thêm input ẩn để lưu tọa độ -->
                    <input type="hidden" id="editLatitude" name="Latitude">
                    <input type="hidden" id="editLongitude" name="Longitude">

                    <!-- Hiển thị bản đồ -->
                    <div class="form-group">
                        <div id="editMap" style="width: 100%; height: 250px;"></div>
                    </div>

                    <button type="button" class="btn btn-light w-100" onclick="addCurrentLocation('edit')">
                        <i class="fas fa-map-marker-alt"></i> Add Current Location
                    </button>

                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-danger" onclick="saveEditedAddress()">Save</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>




@await Html.PartialAsync("_P_Footer")

@section Scripts {

    @* <script src="https://maps.googleapis.com/maps/api/js?key=AIzaSyCjCGmQ0Uq4exrzdcL6rvxywDDOvfAu6eE"></script> *@
    <script src="~/js/gmaps.min.js"></script>
    <script src="~/js/main.js"></script>

}


<!-- Add FontAwesome -->
<script src="https://kit.fontawesome.com/a076d05399.js"></script>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>


           var mapAdd, markerAdd, boundaryAdd;
    var mapEdit, markerEdit, boundaryEdit;
  
  

    // 🔹 KHỞI TẠO MAP
        // 🔹 KHỞI TẠO MAP
    function initMap(lat = 14.0583, lng = 108.2772, type = "add") {
        setTimeout(function () {
            let mapElement = type === "add" ? "map" : "editMap";
            let mapInstance = type === "add" ? mapAdd : mapEdit;
            let markerInstance = type === "add" ? markerAdd : markerEdit;
          

            if (!mapInstance) {
                let newMap = L.map(mapElement, { zoomControl: false }).setView([lat, lng], 7);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; OpenStreetMap contributors'
                }).addTo(newMap);

                let newMarker = L.marker([lat, lng], { draggable: true }).addTo(newMap);

                // ✅ Kích hoạt giới hạn kéo thả
                enableMarkerDrag(newMarker, type);

                if (type === "add") {
                    mapAdd = newMap;
                    markerAdd = newMarker;
                } else {
                    mapEdit = newMap;
                    markerEdit = newMarker;
                }
            } else {
                mapInstance.setView([lat, lng], 7);
                markerInstance.setLatLng([lat, lng]);
                mapInstance.invalidateSize();
            }
        }, 300);
    }


       // Lưu vị trí cũ của marker
    let previousLatLng = { add: null, edit: null };

    function isWithinWard(lat, lng, type = "add") {
        let boundaryInstance = type === "add" ? boundaryAdd : boundaryEdit;
        if (!boundaryInstance) return true; // Nếu chưa có ranh giới, cho phép di chuyển

        let bounds = boundaryInstance.getBounds(); // Lấy phạm vi giới hạn
        let point = L.latLng(lat, lng); // Chuyển vị trí hiện tại thành LatLng

        return bounds.contains(point); // Kiểm tra xem có nằm trong khu vực xã không
    }
    
        function enableMarkerDrag(marker, type = "add") {
        marker.on('dragend', function (event) {
            let newLatLng = event.target.getLatLng();

            if (isWithinWard(newLatLng.lat, newLatLng.lng, type)) {
                // ✅ Nếu trong khu vực, cập nhật vị trí cũ
                previousLatLng[type] = newLatLng;
                getAddressFromCoordinates(newLatLng.lat, newLatLng.lng, type);
            } else {
                // ❌ Nếu ra ngoài khu vực, trả về vị trí cũ
                alert("📍 Bạn không thể di chuyển ra ngoài khu vực xã/phường đã chọn.");
                if (previousLatLng[type]) {
                    marker.setLatLng(previousLatLng[type]); // Trả về vị trí cũ
                }
            }
        });
    }

    // ✅ CHỈ CẬP NHẬT GIỚI HẠN KHI THAY ĐỔI XÃ/PHƯỜNG
          function updateBoundary(type = "add") {
        let city = type === "add" ? $("#tinh option:selected").text() : $("#editCity option:selected").text();
        let district = type === "add" ? $("#quan option:selected").text() : $("#editDistrict option:selected").text();
        let ward = type === "add" ? $("#phuong option:selected").text() : $("#editWard option:selected").text();

        if (!city || !district || !ward) return;

        let fullAddress = `${ward}, ${district}, ${city}, Vietnam`;

        fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(fullAddress)}&polygon_geojson=1`)
            .then(response => response.json())
            .then(data => {
                if (data.length > 0 && data[0].geojson) {
                    const lat = parseFloat(data[0].lat);
                    const lon = parseFloat(data[0].lon);

                    let mapInstance = type === "add" ? mapAdd : mapEdit;
                    let markerInstance = type === "add" ? markerAdd : markerEdit;
                    let boundaryInstance = type === "add" ? boundaryAdd : boundaryEdit;

                    if (mapInstance) {
                        // Xóa ranh giới cũ nếu có
                        if (boundaryInstance) {
                            mapInstance.removeLayer(boundaryInstance);
                        }

                        // Thêm ranh giới mới
                        boundaryInstance = L.geoJSON(data[0].geojson, {
                            style: { color: "transparent", fillOpacity: 0 }
                        }).addTo(mapInstance);

                        // ✅ Cập nhật vị trí cũ khi đổi xã/phường
                        previousLatLng[type] = L.latLng(lat, lon);

                        // Cập nhật map và marker
                        mapInstance.setView([lat, lon], 15, { animate: true });
                        markerInstance.setLatLng([lat, lon]);

                        // Lưu boundary mới
                        if (type === "add") {
                            boundaryAdd = boundaryInstance;
                        } else {
                            boundaryEdit = boundaryInstance;
                        }
                    }
                }
            })
            .catch(error => {
                console.error("Lỗi khi lấy dữ liệu ranh giới:", error);
            });
    }



    // 🔹 CHỈ CẬP NHẬT GIỚI HẠN NẾU NGƯỜI DÙNG THAY ĐỔI INPUT API
    $("#phuong, #editWard").change(function () {
        updateBoundary($(this).attr("id") === "editWard" ? "edit" : "add");
    });

    // ✅ KHI LẤY VỊ TRÍ HIỆN TẠI, KIỂM TRA XEM CÓ NẰM TRONG XÃ KHÔNG
    function addCurrentLocation(type = "add") {
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(
                (position) => {
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;

                    let mapInstance = type === "add" ? mapAdd : mapEdit;
                    let markerInstance = type === "add" ? markerAdd : markerEdit;

                    if (mapInstance && markerInstance) {
                        if (isWithinWard(lat, lng, type)) {
                            mapInstance.setView([lat, lng], 18, { animate: true });
                            markerInstance.setLatLng([lat, lng]);
                            getAddressFromCoordinates(lat, lng, type);
                        } else {
                            alert("📍 Bạn không thể di chuyển ra khu vực xã/phường đã chọn, vui lòng đổi lại xã/phường");
                        }
                    } else {
                        alert("Bản đồ chưa được khởi tạo!");
                    }
                },
                (error) => {
                    alert("Không thể lấy vị trí, kiểm tra GPS và thử lại.");
                },
                { enableHighAccuracy: false }
            );
        } else {
            alert("Trình duyệt không hỗ trợ Geolocation.");
        }
    }

    // 🔥 CHỈ CẬP NHẬT TỌA ĐỘ NẾU NHẬP ĐỊA CHỈ MỚI
    function getCoordinatesFromAddress(address, type = "add") {
        fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}`)
            .then(response => response.json())
            .then(data => {
                if (data.length > 0) {
                    const lat = parseFloat(data[0].lat);
                    const lon = parseFloat(data[0].lon);

                    let mapInstance = type === "add" ? mapAdd : mapEdit;
                    let markerInstance = type === "add" ? markerAdd : markerEdit;

                    if (mapInstance && markerInstance) {
                        if (isWithinWard(lat, lon, type)) {
                            mapInstance.setView([lat, lon], 15, { animate: true });
                            markerInstance.setLatLng([lat, lon]).bindPopup("📍 Đã nhập địa chỉ").openPopup();
                        } else {
                            alert("📍 Bạn không thể di chuyển ra khu vực xã/phường đã chọn, vui lòng đổi lại xã/phường");
                        }
                    }
                }
            })
            .catch(error => {
                alert("Lỗi khi lấy địa chỉ: " + error);
            });
    }

    // Khi chọn tỉnh/quận/phường, cập nhật bản đồ và giới hạn khu vực
    $("#tinh, #editCity").change(function () {
        updateBoundary($(this).attr("id") === "editCity" ? "edit" : "add");
    });
    $("#quan, #editDistrict").change(function () {
        updateBoundary($(this).attr("id") === "editDistrict" ? "edit" : "add");
    });
    $("#phuong, #editWard").change(function () {
        updateBoundary($(this).attr("id") === "editWard" ? "edit" : "add");
    });



        function updateMap(lat, lng, type = "add") {
        let mapInstance = type === "add" ? mapAdd : mapEdit;
        let markerInstance = type === "add" ? markerAdd : markerEdit;

        if (mapInstance && markerInstance) {
            mapInstance.setView([lat, lng], 7, { animate: true }); // 🔥 Đảm bảo zoom nhỏ lại
            markerInstance.setLatLng([lat, lng]);
        }
    }



        $('#addressModal').on('shown.bs.modal', function () {
        initMap(14.0583, 108.2772, "map"); // Mặc định Việt Nam
    });





    $(document).ready(function () {
        // Lấy danh sách tỉnh
        $.getJSON('https://esgoo.net/api-tinhthanh/1/0.htm', function (data) {
            if (data.error === 0) {
                $.each(data.data, function (key, province) {
                    $("#tinh").append('<option value="' + province.id + '">' + province.full_name + '</option>');
                });
            }
        }).fail(function () {
            alert("Không thể lấy danh sách tỉnh thành.");
        });

        // Khi chọn tỉnh
        $("#tinh").change(function () {
            var provinceId = $(this).val();
            $("#quan").html('<option value="0">District</option>');
            $("#phuong").html('<option value="0">Ward</option>');

            if (provinceId > 0) {
                $.getJSON('https://esgoo.net/api-tinhthanh/2/' + provinceId + '.htm', function (data) {
                    if (data.error === 0) {
                        $.each(data.data, function (key, district) {
                            $("#quan").append('<option value="' + district.id + '">' + district.full_name + '</option>');
                        });
                    }
                }).fail(function () {
                    alert("Không thể lấy danh sách quận huyện.");
                });
            }
        });

        // Khi chọn quận
        $("#quan").change(function () {
            var districtId = $(this).val();
            $("#phuong").html('<option value="0">Ward</option>');

            if (districtId > 0) {
                $.getJSON('https://esgoo.net/api-tinhthanh/3/' + districtId + '.htm', function (data) {
                    if (data.error === 0) {
                        $.each(data.data, function (key, ward) {
                            $("#phuong").append('<option value="' + ward.id + '">' + ward.full_name + '</option>');
                        });
                    }
                }).fail(function () {
                    alert("Không thể lấy danh sách phường xã.");
                });
            }
        });

        // Khi chọn phường
        $("#phuong").change(function () {
            const wardName = $(this).find("option:selected").text();
            const districtName = $("#quan option:selected").text();
            const cityName = $("#tinh option:selected").text();
            const fullAddress = `${wardName}, ${districtName}, ${cityName}`;
            getCoordinatesFromAddress(fullAddress);
        });
    });

          function addCurrentLocation(type = "add") {
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(
                (position) => {
                    const lat = position.coords.latitude;
                    const lng = position.coords.longitude;

                    // Kiểm tra modal nào đang mở
                    let mapInstance = type === "add" ? mapAdd : mapEdit;
                    let markerInstance = type === "add" ? markerAdd : markerEdit;

                    if (mapInstance && markerInstance) {
                        // Cập nhật vị trí trung tâm bản đồ
                        mapInstance.setView([lat, lng], 18, { animate: true });

                        // Cập nhật vị trí marker
                        markerInstance.setLatLng([lat, lng]);

                        // Lấy địa chỉ từ tọa độ mới
                        getAddressFromCoordinates(lat, lng);
                    } else {
                        alert("Bản đồ chưa được khởi tạo!");
                    }
                },
                (error) => {
                    alert("Không thể lấy vị trí, kiểm tra GPS và thử lại.");
                },
                { enableHighAccuracy: false } // Tắt để kiểm tra phản hồi nhanh hơn
            );
        } else {
            alert("Trình duyệt không hỗ trợ Geolocation.");
        }
    }





    function getAddressFromCoordinates(lat, lng, type = "add") {
        const url = `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`;

        fetch(url)
            .then(response => response.json())
            .then(data => {
                if (data && data.display_name) {
                    let inputField = type === "add" ? "addressInput" : "editAddressLine";
                    document.getElementById(inputField).value = data.display_name;
                } else {
                    alert("Không tìm thấy địa chỉ.");
                }
            })
            .catch(error => {
                alert("Lỗi khi lấy địa chỉ: " + error);
            });
    }

    function suggestAddress() {
        let input = document.getElementById("addressInput").value;
        let ward = $("#phuong option:selected").text();
        let district = $("#quan option:selected").text();
        let city = $("#tinh option:selected").text();

        if (input.length < 3) {
            document.getElementById("suggestions").innerHTML = "";
            return;
        }

        let query = `${input}, ${ward}, ${district}, ${city}, Vietnam`;
        let url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}`;

        fetch(url)
            .then(response => response.json())
            .then(data => {
                let suggestions = document.getElementById("suggestions");
                suggestions.innerHTML = "";
                data.forEach(place => {
                    let li = document.createElement("li");
                    li.classList.add("list-group-item");
                    li.innerText = place.display_name;
                    li.onclick = function () {
                        document.getElementById("addressInput").value = place.display_name;
                        suggestions.innerHTML = "";
                    };
                    suggestions.appendChild(li);
                });
            })
            .catch(error => console.log("Lỗi gợi ý địa chỉ:", error));
    }

    ///
              function updateMapAfterSelection(type = "add") {
        let city = type === "add" ? $("#tinh option:selected").text() : $("#editCity option:selected").text();
        let district = type === "add" ? $("#quan option:selected").text() : $("#editDistrict option:selected").text();
        let ward = type === "add" ? $("#phuong option:selected").text() : $("#editWard option:selected").text();

        // Kiểm tra xem các giá trị có rỗng không
        if (!city || !district) {
            console.log("⚠ Chưa chọn đủ tỉnh/thành & quận/huyện, không gọi API.");
            return;
        }

        let fullAddress = ward ? `${ward}, ${district}, ${city}, Vietnam` : `${district}, ${city}, Vietnam`;

        console.log(`📌 Cập nhật bản đồ với địa chỉ: ${fullAddress}`);

        getCoordinatesFromAddress(fullAddress, type);
    }


        // Khi chọn tỉnh trong modal Edit
    $('#editCity').change(function () {
        loadDistricts($(this).val(), "", "edit").done(function () {
            updateMapAfterSelection("edit");
        });
    });

    // Khi chọn quận trong modal Edit
    $('#editDistrict').change(function () {
        loadWards($(this).val(), "", "edit").done(function () {
            updateMapAfterSelection("edit");
        });
    });

    // Khi chọn phường trong modal Edit
    $('#editWard').change(function () {
        updateMapAfterSelection("edit");
    });


</script>






<script>

    //    
    //
              function addAddress() {
        let formData = $('#addAddressForm').serializeArray();

        // Lấy ID và tên từ dropdown
        let cityId = $("#tinh").val();
        let districtId = $("#quan").val();
        let wardId = $("#phuong").val();
        let cityName = $("#tinh option:selected").text();
        let districtName = $("#quan option:selected").text();
        let wardName = $("#phuong option:selected").text();

        // Gửi cả ID và tên về server
        formData = formData.map(field => {
            if (field.name === "City") field.value = cityName;  // Lưu tên vào DB
            if (field.name === "District") field.value = districtName;
            if (field.name === "Ward") field.value = wardName;
            return field;
        });

        // Gửi ID để API có thể sử dụng
        formData.push({ name: "CityId", value: cityId });
        formData.push({ name: "DistrictId", value: districtId });
        formData.push({ name: "WardId", value: wardId });
        formData.push({ name: "IsDefault", value: $("#isDefault").prop("checked") ? "true" : "false" });


        formData.push({ name: "UserId", value: $('#userId').val() });

        $.ajax({
            url: '/Address/Add',
            type: 'POST',
            data: $.param(formData), // Gửi cả ID và tên
            success: function (response) {
                if (response.success) {
                    alert("Thêm địa chỉ thành công!");

                    // **Hiển thị địa chỉ đầy đủ trong input**
                    $("#addressInput").val(`${wardName}, ${districtName}, ${cityName}`);

                    // **Reset form**
                    resetAddAddressForm();

                    // **Ẩn modal**
                    $('#addressModal').modal('hide');

                    // **Cập nhật danh sách địa chỉ mà không cần F5**
                    loadAddresses();
                } else {
                    alert(response.message);
                }
            },
            error: function () {
                alert('Lỗi khi thêm địa chỉ.');
            }
        });
    }




        function resetAddAddressForm() {
        $('#addAddressForm')[0].reset(); // Reset toàn bộ form

        // Reset dropdown về trạng thái mặc định
        $('#tinh').val("").trigger("change");
        $('#quan').empty().append('<option value="">Select District</option>');
        $('#phuong').empty().append('<option value="">Select Ward</option>');

        // Reset input địa chỉ
        $('#addressInput').val("");

        // Reset bản đồ về vị trí mặc định
        if (mapAdd && markerAdd) {
            mapAdd.setView([14.0583, 108.2772], 6);
            markerAdd.setLatLng([14.0583, 108.2772]);
        }
    }



             function deleteAddress(addressId) {
        if (!confirm("Bạn có chắc chắn muốn xóa địa chỉ này?")) return;

        $.ajax({
            url: '/Address/Delete/' + addressId,
            type: 'DELETE',
            success: function (response) {
                if (response.success) {
                    // Xóa phần tử HTML tương ứng với địa chỉ đã xóa
                    $("#address-" + addressId).fadeOut(300, function () {
                        $(this).remove();
                    });
                    loadAddresses();
                } else {
                    alert(response.message || "Lỗi khi xóa địa chỉ.");
                }
            },
            error: function () {
                alert("Đã xảy ra lỗi khi xóa địa chỉ.");
            }
        });
    }



    // Cập nhật địa chỉ
    function updateAddress() {
        $.ajax({
            url: '/Address/Update',
            type: 'POST',
            data: $('#editAddressForm').serialize(),
            success: function (response) {
                if (response.success) {
                    $('#editAddressModal').modal('hide');
                    loadAddresses();
                } else {
                    alert(response.message);
                }
            },
            error: function () {
                alert('Lỗi khi cập nhật địa chỉ.');
            }
        });
    }

    // Đặt địa chỉ mặc định
       function setDefault(addressId) {
        $.ajax({
            url: '/Address/SetDefault',  // API xử lý cập nhật trạng thái
            type: 'POST',
            data: { id: addressId },
            success: function (response) {
                if (response.success) {
                    alert('Cập nhật địa chỉ mặc định thành công!');
                    loadAddresses(); // Reload danh sách địa chỉ sau khi cập nhật
                } else {
                    alert(response.message);
                }
            },
            error: function () {
                alert('Có lỗi xảy ra, vui lòng thử lại!');
            }
        });
    }


      function loadAddresses() {
        $.ajax({
            url: '/Address/GetAddresses', // Gọi API lấy danh sách địa chỉ
            type: 'GET',
            success: function (response) {
                if (response.success) {
                    let listHtml = '';
                    response.addresses.forEach(address => {
                        listHtml += `
                            <div class="list-group-item">
                            <h5>${address.fullName}</h5>
                            <h5>${address.phoneNumber}</h5>
                                <h5>${address.addressLine}</h5>
                                <p>${address.city}, ${address.district}, ${address.ward}</p>
                                <span class="badge ${address.isDefault ? 'badge-success' : 'badge-secondary'}">
                                    ${address.isDefault ? 'Default' : ''}
                                </span>
                                <div class="mt-2">
                                    <button class="btn btn-secondary btn-sm" onclick="editAddress(${address.id})">Edit</button>
                                    <button class="btn btn-danger btn-sm" onclick="deleteAddress(${address.id})">Delete</button>
                                    ${!address.isDefault ? `<button class="btn btn-sm btn-default" onclick="setDefault(${address.id})">Set as default</button>` : ''}
                                </div>
                            </div>
                        `;
                    });
                    $('.list-group').html(listHtml); // Cập nhật giao diện
                } else {
                    alert(response.message);
                }
            },
            error: function () {
                alert('Lỗi khi tải danh sách địa chỉ.');
            }
        });
    }

    // Gọi loadAddresses khi trang được tải
    $(document).ready(function () {
        loadAddresses();
    });




        function saveEditedAddress() {
        let data = {
            Id: $('#editAddressId').val(),
            FullName: $('#editFullName').val(),
            PhoneNumber: $('#editPhoneNumber').val(),
            AddressLine: $('#editAddressLine').val(),
            City: $("#editCity option:selected").text(), // Lưu tên tỉnh
            District: $("#editDistrict option:selected").text(), // Lưu tên quận
            Ward: $("#editWard option:selected").text(), // Lưu tên phường
            IsDefault: $('#editIsDefault').is(":checked")
        };

        $.ajax({
            url: '/Address/Update',
            type: 'POST',
            contentType: 'application/json',
            data: JSON.stringify(data),
            success: function (res) {
                if (res.success) {
                    alert("Cập nhật thành công!");

                    // **Cập nhật lại input tỉnh/quận/phường**
                    $("#editAddressLine").val(`${data.Ward}, ${data.District}, ${data.City}`);

                    // **Ẩn modal sửa**
                    $('#editAddressModal').modal('hide');

                    // **Cập nhật danh sách địa chỉ mà không cần F5**
                    loadAddresses();
                } else {
                    alert(res.message);
                }
            }
        });
    }


   

</script>
<script>
                                 function editAddress(id) {
        $.ajax({
            url: "/Address/GetById",
            type: "GET",
            data: { id: id },
            success: function (response) {
                if (response.success) {
                    let address = response.data;

                    $('#editAddressId').val(address.id);
                    $('#editFullName').val(address.fullName);
                    $('#editPhoneNumber').val(address.phoneNumber);
                    $('#editAddressLine').val(address.addressLine);
                    $('#editLatitude').val(address.latitude || '');
                    $('#editLongitude').val(address.longitude || '');

                    $('#editAddressModal').modal('show');

                    console.log("🟢 Đang load dữ liệu tỉnh/thành/quận/xã...");

                    // Load tỉnh -> Load quận -> Load xã -> Gọi bản đồ
                    loadCities(address.cityId, "edit").done(function () {
                        loadDistricts(address.cityId, address.districtId, "edit").done(function () {
                            loadWards(address.districtId, address.wardId, "edit").done(function () {
                                console.log("✅ Dữ liệu tỉnh/thành đã tải xong. Cập nhật bản đồ.");
                                updateMapAfterSelection("edit"); // Chắc chắn cập nhật bản đồ
                            });
                        });
                    });

                    // 🟢 Hiển thị bản đồ đúng tọa độ nếu có
                    let lat = address.latitude ? parseFloat(address.latitude) : 14.0583;
                    let lon = address.longitude ? parseFloat(address.longitude) : 108.2772;
                    initMap(lat, lon, "edit");

                    console.log(`📌 Bản đồ sửa địa chỉ: ${lat}, ${lon}`);
                } else {
                    alert("Không tìm thấy địa chỉ!");
                }
            },
            error: function () {
                alert("Lỗi khi tải dữ liệu địa chỉ.");
            }
        });
    }

</script>


<script>

        function loadCities(selectedCityId = "", type = "add") {
        let cityDropdown = type === "add" ? "#tinh" : "#editCity";

        return $.getJSON("https://esgoo.net/api-tinhthanh/1/0.htm", function (data) {
            if (data.error === 0) {
                $(cityDropdown).empty().append('<option value="">Select City</option>');
                $.each(data.data, function (key, province) {
                    let isSelected = province.id == selectedCityId ? "selected" : "";
                    $(cityDropdown).append(`<option value="${province.id}" ${isSelected}>${province.full_name}</option>`);
                });

                // Nếu có tỉnh được chọn thì gọi API quận/huyện
                if (selectedCityId) {
                    $(cityDropdown).trigger("change");
                }
            } else {
                alert("Không thể lấy danh sách tỉnh thành.");
            }
        }).fail(function () {
            alert("Không thể lấy danh sách tỉnh thành.");
        });
    }


        function loadDistricts(cityId, selectedDistrictId = "", type = "add") {
        if (!cityId) return;
        let districtDropdown = type === "add" ? "#quan" : "#editDistrict";

        return $.getJSON(`https://esgoo.net/api-tinhthanh/2/${cityId}.htm`, function (data) {
            if (data.error === 0) {
                $(districtDropdown).empty().append('<option value="">Select District</option>');
                $.each(data.data, function (key, district) {
                    let isSelected = district.id == selectedDistrictId ? "selected" : "";
                    $(districtDropdown).append(`<option value="${district.id}" ${isSelected}>${district.full_name}</option>`);
                });

                // Nếu có quận/huyện được chọn thì gọi API phường/xã
                if (selectedDistrictId) {
                    $(districtDropdown).trigger("change");
                }
            } else {
                
            }
        }).fail(function () {
            
        });
    }

            function loadWards(districtId, selectedWardId = "", type = "add") {
        if (!districtId) return;
        let wardDropdown = type === "add" ? "#phuong" : "#editWard";

        return $.getJSON(`https://esgoo.net/api-tinhthanh/3/${districtId}.htm`, function (data) {
            if (data.error === 0) {
                $(wardDropdown).empty().append('<option value="">Select Ward</option>');
                $.each(data.data, function (key, ward) {
                    let isSelected = ward.id == selectedWardId ? "selected" : "";
                    $(wardDropdown).append(`<option value="${ward.id}" ${isSelected}>${ward.full_name}</option>`);
                });
            } else {
               
            }
        }).fail(function () {
            
        });
    }

        $('#editCity').change(function () {
        let provinceId = $(this).val();
        $("#editDistrict").empty().append('<option value="">Select District</option>');
        $("#editWard").empty().append('<option value="">Select Ward</option>');

        if (provinceId) {
            loadDistricts(provinceId, "", "edit");
        }
    });


        $('#editDistrict').change(function () {
        let districtId = $(this).val();
        $("#editWard").empty().append('<option value="">Select Ward</option>');

        if (districtId) {
            loadWards(districtId, "", "edit");
        }
    });


               function saveEditedAddress() {
        let address = {
            Id: $("#editAddressId").val(),
            FullName: $("#editFullName").val(),
            PhoneNumber: $("#editPhoneNumber").val(),
            AddressLine: $("#editAddressLine").val(),

            CityId: $("#editCity").val(), 
            DistrictId: $("#editDistrict").val(),
            WardId: $("#editWard").val(),

            City: $("#editCity option:selected").text(),
            District: $("#editDistrict option:selected").text(),
            Ward: $("#editWard option:selected").text(),

            IsDefault: $("#editIsDefault").is(":checked")
        };

        $.ajax({
            url: "/Address/Update",
            type: "POST",
            contentType: "application/json",
            data: JSON.stringify(address),
            success: function (response) {
                if (response.success) {
                    alert("Cập nhật thành công!");
                    $("#editAddressModal").modal("hide");
                    loadAddresses();
                } else {
                    alert("Lỗi cập nhật!");
                }
            }
        });
    }
</script>