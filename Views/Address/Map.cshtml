

<head>
    <!-- Mobile Specific Meta -->
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <!-- Favicon-->
    <link rel="shortcut icon" href="img/fav.png">
    <!-- Author Meta -->
    <meta name="author" content="CodePixar">
    <!-- Site Title -->
    <title>Karma Shop</title>

    <!-- CSS -->
    <link rel="stylesheet" href="css/bootstrap.css">
    <link rel="stylesheet" href="css/main.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
</head>

<body>

    <!-- Button to open modal -->
    <button type="button" class="btn btn-primary" data-toggle="modal" data-target="#addressModal" onclick="initMap()">
        Enter Address
    </button>

    <!-- Modal -->
    <div class="modal fade" id="addressModal" tabindex="-1" role="dialog" aria-labelledby="addressModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">New Address</h5>
                    <button type="button" class="close" data-dismiss="modal">&times;</button>
                </div>
                <div class="modal-body">
                    <form>
                        <div class="form-row">
                            <div class="form-group col-md-6">
                                <label for="fullName">Full Name:</label>
                                <input type="text" class="form-control" id="fullName" required>
                            </div>
                            <div class="form-group col-md-6">
                                <label for="phoneNumber">Phone Number:</label>
                                <input type="text" class="form-control" id="phoneNumber" required>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group col-md-4">
                                <label for="city">City:</label>
                                <select class="form-control" id="tinh" required>
                                    <option value="0">Select City</option>
                                </select>
                            </div>
                            <div class="form-group col-md-4">
                                <label for="district">District:</label>
                                <select class="form-control" id="quan" required>
                                    <option value="0">Select District</option>
                                </select>
                            </div>
                            <div class="form-group col-md-4">
                                <label for="ward">Ward:</label>
                                <select class="form-control" id="phuong" required>
                                    <option value="0">Select Ward</option>
                                </select>
                            </div>
                        </div>

                        <input type="text" id="addressInput" class="form-control" placeholder="Nhập số nhà, đường, ấp..." onkeyup="suggestAddress()">
                        <ul id="suggestions" class="list-group"></ul>



                        <div class="form-group">
                            <div id="map" style="width: 100%; height: 250px;"></div>
                        </div>
                        <button type="button" class="btn btn-light w-100" onclick="addCurrentLocation()">
                            <i class="fas fa-map-marker-alt"></i> Add Current Location
                        </button>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-light" data-dismiss="modal">Cancel</button>
                            <button type="button" class="btn btn-danger">Submit</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Add FontAwesome -->
    <script src="https://kit.fontawesome.com/a076d05399.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

    <script>
        let map, marker;

        function initMap() {
            if (!map) {
                map = L.map('map', { zoomControl: false }).setView([14.0583, 108.2772], 6);
                L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                    attribution: '&copy; OpenStreetMap contributors'
                }).addTo(map);

                // Thêm marker có thể kéo
                marker = L.marker([14.0583, 108.2772], { draggable: true }).addTo(map);

                // Cập nhật địa chỉ khi kéo marker
                marker.on('dragend', function (event) {
                    const newLatLng = event.target.getLatLng();
                    getAddressFromCoordinates(newLatLng.lat, newLatLng.lng);
                });
            }

            $('#addressModal').on('shown.bs.modal', function () {
                setTimeout(() => {
                    map.invalidateSize();
                }, 300);
            });
        }

        $(document).ready(function () {
            // Lấy danh sách tỉnh
            $.getJSON('https://esgoo.net/api-tinhthanh/1/0.htm', function (data) {
                if (data.error === 0) {
                    $.each(data.data, function (key, province) {
                        $("#tinh").append('<option value="' + province.id + '">' + province.full_name + '</option>');
                    });
                }
            }).fail(function () {
                alert("Không thể lấy danh sách tỉnh thành.");
            });

            // Khi chọn tỉnh
            $("#tinh").change(function () {
                var provinceId = $(this).val();
                $("#quan").html('<option value="0">District</option>');
                $("#phuong").html('<option value="0">Ward</option>');

                if (provinceId > 0) {
                    $.getJSON('https://esgoo.net/api-tinhthanh/2/' + provinceId + '.htm', function (data) {
                        if (data.error === 0) {
                            $.each(data.data, function (key, district) {
                                $("#quan").append('<option value="' + district.id + '">' + district.full_name + '</option>');
                            });
                        }
                    }).fail(function () {
                        alert("Không thể lấy danh sách quận huyện.");
                    });
                }
            });

            // Khi chọn quận
            $("#quan").change(function () {
                var districtId = $(this).val();
                $("#phuong").html('<option value="0">Ward</option>');

                if (districtId > 0) {
                    $.getJSON('https://esgoo.net/api-tinhthanh/3/' + districtId + '.htm', function (data) {
                        if (data.error === 0) {
                            $.each(data.data, function (key, ward) {
                                $("#phuong").append('<option value="' + ward.id + '">' + ward.full_name + '</option>');
                            });
                        }
                    }).fail(function () {
                        alert("Không thể lấy danh sách phường xã.");
                    });
                }
            });

            // Khi chọn phường
            $("#phuong").change(function () {
                const wardName = $(this).find("option:selected").text();
                const districtName = $("#quan option:selected").text();
                const cityName = $("#tinh option:selected").text();
                const fullAddress = `${wardName}, ${districtName}, ${cityName}`;
                getCoordinatesFromAddress(fullAddress);
            });
        });

        function addCurrentLocation() {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(
                    (position) => {
                        const userLocation = [position.coords.latitude, position.coords.longitude];
                        map.setView(userLocation, 15);
                        marker.setLatLng(userLocation);
                        getAddressFromCoordinates(userLocation[0], userLocation[1]); // Cập nhật địa chỉ từ tọa độ
                    },
                    (error) => {
                        alert("Không thể lấy vị trí, kiểm tra GPS và thử lại.");
                    },
                    { enableHighAccuracy: true } // Sử dụng chế độ chính xác cao
                );
            } else {
                alert("Trình duyệt không hỗ trợ Geolocation.");
            }
        }

        function getCoordinatesFromAddress(address) {
            const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(address)}`;

            fetch(url)
                .then(response => response.json())
                .then(data => {
                    if (data.length > 0) {
                        const lat = data[0].lat;
                        const lon = data[0].lon;
                        map.setView([lat, lon], 15);
                        marker.setLatLng([lat, lon]).bindPopup("Vị trí đã nhập").openPopup();
                        document.getElementById("addressInput").value = data[0].display_name; // Cập nhật tên địa chỉ
                    } else {
                        alert("Không tìm thấy địa chỉ.");
                    }
                })
                .catch(error => {
                    alert("Lỗi khi lấy tọa độ: " + error);
                });
        }

        function getAddressFromCoordinates(lat, lng) {
            const url = `https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}`;

            fetch(url)
                .then(response => response.json())
                .then(data => {
                    if (data && data.display_name) {
                        document.getElementById("addressInput").value = data.display_name; // Cập nhật địa chỉ hiển thị
                    } else {
                        alert("Không tìm thấy địa chỉ.");
                    }
                })
                .catch(error => {
                    alert("Lỗi khi lấy địa chỉ: " + error);
                });
        }
        function suggestAddress() {
            let input = document.getElementById("addressInput").value;
            let ward = $("#phuong option:selected").text();
            let district = $("#quan option:selected").text();
            let city = $("#tinh option:selected").text();

            if (input.length < 3) {
                document.getElementById("suggestions").innerHTML = "";
                return;
            }

            let query = `${input}, ${ward}, ${district}, ${city}, Vietnam`;
            let url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}`;

            fetch(url)
                .then(response => response.json())
                .then(data => {
                    let suggestions = document.getElementById("suggestions");
                    suggestions.innerHTML = "";
                    data.forEach(place => {
                        let li = document.createElement("li");
                        li.classList.add("list-group-item");
                        li.innerText = place.display_name;
                        li.onclick = function () {
                            document.getElementById("addressInput").value = place.display_name;
                            suggestions.innerHTML = "";
                        };
                        suggestions.appendChild(li);
                    });
                })
                .catch(error => console.log("Lỗi gợi ý địa chỉ:", error));
        }



    </script>

</body>

</html>