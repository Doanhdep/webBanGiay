@model MyStore.myDTO.Product_Price_DTO
@{
	ViewData["Title"] = "Detail";
	var listFilename = ViewBag.listFilename as List<string>;
	var min_price_afterdis = ViewBag.min_price_afterdis;
	var max_price_afterdis = ViewBag.max_price_afterdis;
	var listSize = ViewBag.listSize as List<string>;

}

@section Styles {


	<style>
		#mainImageContainer {
			transition: opacity 0.5s ease-in-out;
			opacity: 0;
			display: none;
		}

			#mainImageContainer.show {
				opacity: 1;
				display: block;
			}

		#thumbnailContainer .thumbnail img {
			width: 80px;
			height: 80px;
			object-fit: cover;
			cursor: pointer;
			border: 2px solid transparent;
		}

			#thumbnailContainer .thumbnail img:hover {
				border-color: red;
			}


		#mainImageContainer {
			text-align: center;
			margin-top: 5px;
			margin-bottom: 5px;
			min-width: 300px;
			min-height: 300px;
			max-width: 450px;
			max-height: 500px;
		}

			#mainImageContainer img {
				max-width: 90%;
				max-height: 90vh;
				border-radius: 5px;
			}
	</style>
}
<!-- Start Banner Area -->
<section class="banner-area organic-breadcrumb">
	<div class="container">
		<div class="breadcrumb-banner d-flex flex-wrap align-items-center justify-content-end">
			<div class="col-first">
				<h1>Trang Sản Phẩm Chi Tiết </h1>
				<nav class="d-flex align-items-center">
					<a href="index.html">Trang chủ<span class="lnr lnr-arrow-right"></span></a>
					<a href="#">Cửa hàng<span class="lnr lnr-arrow-right"></span></a>
					<a href="single-product.html">Sản phẩm chi tiết</a>
				</nav>
			</div>
		</div>
	</div>
</section>
<!-- End Banner Area -->
<!--================Single Product Area =================-->
<div class="product_image_area">
	<div class="container">
		<div class="row s_product_inner">
			<div class="col-lg-6">
				<div class="s_Product_carousel">
					@foreach (var item in listFilename)
					{
						<div class="single-prd-item">
							<a class="zoom-wrapper">
								<img src='~/Image/@item' alt="Giày, áo quần, đồng hồ chất lượng cao chính hãng tại bandathang.store" />
							</a>
						</div>
					}
				</div>

			</div>
			<div class="col-lg-5 offset-lg-1 ">
				<div class="s_product_text">
					<h3>@Model.Title</h3>
					<h2 style="display: inline;" id="price_ajax">
						@String.Format(new System.Globalization.CultureInfo("vi-VN"), "{0:N0} ₫", min_price_afterdis) -
						@String.Format(new System.Globalization.CultureInfo("vi-VN"), "{0:N0} ₫", max_price_afterdis)
					</h2>

					<s id="tag_wait_ajax"></s>

					<div>
						<a href="#" data-toggle="modal" data-target="#sizeModal">
							<i class="fas fa-file"></i>
							Xem bảng size
						</a>
					</div>
					<div class="text-danger font-weight-bold mb-2">
						Hàng chất lượng, Fullbox, Cam kết 100% chính hãng, Phát hiện hàng giả xin đền 10 lần tiền.
					</div>
					<div class="font-weight-bold mb-2">
						Miễn phí đổi size | đổi mẫu trong 1 tuần !!!
					</div>
					<div class="text-primary font-weight-bold">
						Showroom : Khu phố 5, Trảng Dài, Biên Hòa, Đồng Nai
					</div>

					<!-- Modal -->
					<div class="modal fade" id="sizeModal" tabindex="-1" role="dialog" aria-labelledby="sizeModalLabel" aria-hidden="true">
						<div class="modal-dialog" role="document">
							<div class="modal-content">
								<div class="modal-header">
									<h5 class="modal-title" id="sizeModalLabel">Bảng Size</h5>
									<button type="button" class="close" data-dismiss="modal" aria-label="Close">
										<span aria-hidden="true">&times;</span>
									</button>
								</div>
								@if (Model.CategoryId == 1)
								{
								}
								<div class="modal-body text-center">
									<!-- Ảnh bảng size -->
									@if (Model.CategoryId == 1)
									{
										<img src="~/Image/bangsizegiaynew.png" class="img-fluid" alt="Bảng size">
									}
									else if (Model.CategoryId == 2)
									{
										<img src="~/Image/bangsizeao.png" class="img-fluid" alt="Bảng size">

									}
									else
									{
										<img src="~/Image/bangsizedongho.png" class="img-fluid" alt="Bảng size">

									}

								</div>

							</div>
						</div>
					</div>

					<div class="size-wrap">
						<div class="block-26 mb-1">
							<h4 class="font-weight-bold">Size</h4>
							<ul>
								@foreach (var item in listSize)
								{
									<li><a onclick="getProductPrice(@Model.ProductId,@item)">@item</a></li>
								}

							</ul>
						</div>
					</div>
					<div>
						<h6 class="font-weight-bold">Số Lượng :</h6>
					</div>
					<div class="product_count">

						<input type="text" name="qty" id="sst" maxlength="12" value="1" title="Quantity:" class="input-text qty">
						<button onclick="var result = document.getElementById('sst'); var sst = result.value; if( !isNaN( sst )) result.value++;return false;"
								class="increase items-count" type="button">
							<i class="lnr lnr-chevron-up"></i>
						</button>
						<button onclick="var result = document.getElementById('sst'); var sst = result.value; if( !isNaN( sst ) &amp;&amp; sst > 0 ) result.value--;return false;"
								class="reduced items-count" type="button">
							<i class="lnr lnr-chevron-down"></i>
						</button>
					</div>
					<div class="card_area d-flex align-items-center">
						<a class="primary-btn" href="#">Thêm vào giỏ hàng</a>
						<a class="icon_btn" href="#"><i class="lnr lnr lnr-diamond"></i></a>
						<a class="icon_btn" href="#"><i class="lnr lnr lnr-heart"></i></a>
					</div>
				</div>
			</div>
		</div>
	</div>
</div>
<!--================End Single Product Area =================-->
<!--================Product Description Area =================-->
<section class="product_description_area">
	<div class="container">
		<ul class="nav nav-tabs" id="myTab" role="tablist">
			<li class="nav-item">
				<a class="nav-link active" id="home-tab" data-toggle="tab" href="#home" role="tab" aria-controls="home" aria-selected="true">Mô Tả</a>
			</li>
			<li class="nav-item">
				<a class="nav-link" id="profile-tab" data-toggle="tab" href="#profile" role="tab" aria-controls="profile"
				   aria-selected="false">Thông Số Sản Phẩm</a>
			</li>
			<li class="nav-item">
