				<p>
					@Html.Raw(Model.Description)
				</p>

			</div>
			<div class="tab-pane fade" id="profile" role="tabpanel" aria-labelledby="profile-tab">
				<div class="table-responsive">
					<table class="table">
						<tbody>
							<tr>
								<td>
									<h5>Trọng Lượng </h5>
								</td>
								<td>
									<h5>@Model.Weight</h5>
								</td>
							</tr>
							<tr>
								<td>
									<h5>Loại Sản Phẩm </h5>
								</td>
								<td>
									<h5>@Model.CategoryName</h5>
								</td>
							</tr>
							<tr>
								<td>
									<h5>Nhà Cung Cấp</h5>
								</td>
								<td>
									<h5>@Model.SupplierName</h5>
								</td>
							</tr>
							<tr>
								<td>
									<h5>Màu Sắc </h5>
								</td>
								<td>
									<h5>@Model.Color</h5>
								</td>
							</tr>
							<tr>
								<td>
									<h5>Chất Liệu Sản Xuất</h5>
								</td>
								<td>
									<h5>@Model.Material</h5>
								</td>
							</tr>
							<tr>
								<td>
									<h5>Ngày Sản Xuất</h5>
								</td>
								<td>
									<h5>@Model.ManufactureDate</h5>
								</td>
							</tr>
							<tr>
								<td>
									<h5>Xuất Xứ</h5>
								</td>
								<td>
									<h5>@Model.CountryOfOrigin</h5>
								</td>
							</tr>
							<tr>
								<td>
									<h5>Thời Gian Bảo Hành </h5>
								</td>
								<td>
									<h5>@Model.WarrantyPeriod</h5>
								</td>
							</tr>
						</tbody>
					</table>
				</div>
			</div>
			<div class="tab-pane fade " id="contact" role="tabpanel" aria-labelledby="contact-tab">
				<div class="row total_rate  rating-container">
					<div class="col-6">
						<div class="box_total mb-3">
							<h5 id="scrollfeedback">Đánh Giá </h5>
							<h4 id="rating"> 4.8 <i class="fa fa-star "></i> </h4>

							<h6 id="total-reviews">(03 Reviews)</h6>
						</div>
					</div>
					<div class="col-6">

						<div class="button-group-area">
							<a id="All" style="width:150px" onclick="loadFeedbacks(@Model.ProductId, 1, 0)" class="genric-btn warning-border">Tất cả(11.0k)</a>
							<a id="5_star" style="width:150px" onclick="loadFeedbacks( @Model.ProductId,1, 5)" class="genric-btn warning-border">5 Sao(4.3k)</a>
							<a id="4_star" style="width:150px" onclick="loadFeedbacks( @Model.ProductId,1, 4)" class="genric-btn warning-border">4 Sao(3.3k)</a>
							<a id="3_star" style="width:150px" onclick="loadFeedbacks( @Model.ProductId,1, 3)" class="genric-btn warning-border">3 Sao(2.4k)</a>
							<a id="2_star" style="width:150px" onclick="loadFeedbacks(@Model.ProductId, 1, 2)" class="genric-btn warning-border">2 Sao(1.2k)</a>
							<a id="1_star" style="width:150px" onclick="loadFeedbacks( @Model.ProductId,1, 1)" class="genric-btn warning-border">1 Sao(241)</a>

