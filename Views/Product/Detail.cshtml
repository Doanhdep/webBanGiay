				</div>
			</div>
			<div class="col-lg-3">
				<div class="ctg-right">
					<a href="#" target="_blank">
						<img class="img-fluid d-block mx-auto" src="~/img/category/c5.jpg" alt="">
					</a>
				</div>
			</div>
		</div>
	</div>
</section>






@section Scripts
{


	<script>


		// ajax rationg count
			function loadRating(productId) {
				$.ajax({
					url: "/Product/GetRating",
					type: "GET",
					data: { productId: productId },
					success: function (response) {
						if (response.success) {
												$("#rating").html(response.rating + ' <i class="fa fa-star"></i>');
												$("#All").html('Tất cả ('+response.totalReviews+')');
												$("#1_star").html('1 Sao ('+response.oneStar+')');
												$("#2_star").html('2 Sao ('+response.twoStars+')');
												$("#3_star").html('3 Sao ('+response.threeStars+')');
												$("#4_star").html('4 Sao ('+response.fourStars+')');
												$("#5_star").html('5 Sao ('+response.fiveStars+')');
												$("#a_star").html('Ảnh ('+response.fiveStars+')');
								$("#total-reviews").text('(' + response.totalReviews + ' Đánh giá)');
						}
					},
					error: function () {
						console.error("Failed to load rating data.");
					}
				});
			}



			// ajax feedback


				let currentPage = 1;
				let pageSize = 5;
				let fillter = 0 ;
				function loadFeedbacks(productId,page = 1, fillter ) {
				// cuộn lên
						scrollToElement("scrollfeedback");
				$.ajax({
					url: "/Product/GetFeedbacks",
					type: "GET",
							data: {productId:productId, page: page, pageSize: pageSize,fillter:fillter }, // Gửi thông tin phân trang lên server
					success: function (response) {
						console.log("AJAX gọi thành công");
						if (response.success) {

							let html = "";

							response.data.forEach(feedback => {
								let stars = "";
								for (let i = 0; i < feedback.star; i++) {
									stars += `<i class="fa fa-star text-warning"></i>`;
								}

								html += `<div class="review_item">
											<div class="media">
												<div class="d-flex">
													<img style="width: 60px; height: 60px; object-fit: cover;border-radius: 50%" src="/Image/${feedback.filenameuser}" alt="">
												</div>
												<div class="media-body">
													<h4>${feedback.fullname}</h4>
													<h5>${new Date(feedback.createdAt).toLocaleString()}</h5>
													<ul class="list-inline">${stars}</ul>
												</div>
											</div>
											<p>${feedback.note}</p>
										</div>`;

								// Hiển thị hình ảnh nếu có
								if (feedback.filenames && feedback.filenames.length > 0) {
									html += `<div class="container mt-4">
												<div class="row justify-content-center">
													<div class="col-12 text-center">
														<div id="thumbnailContainer" class="d-flex justify-content-left">`;

									html += feedback.filenames.map(file => `
										<button class="btn p-0 thumbnail m-1" onclick="showLargeImage('~/Image/${file}')">
											<img src="/Image/${file}" class="img-thumbnail">
										</button>
									`).join('');
									html += `        </div>
													</div>
													<div class="col-12">
														<div id="mainImageContainer" class="collapse">
															<img id="largeImage" src="/img/ob1.jpg" class="img-fluid">
														</div>
													</div>
												</div>
											</div>`;
								}

								// Hiển thị phản hồi từ Admin nếu có
								if (feedback.noterely != null && feedback.noterely != "") {
									html += `<div class="review_item reply">
												<div class="media">
													<div class="d-flex">
													<img style="width: 60px; height: 60px; object-fit: cover;border-radius: 50%" src="/Image/${feedback.filenameuserrely}" alt="">
													</div>
													<div class="media-body">
														<h4>${feedback.fullnamerely || 'Admin'}</h4>
													</div>
												</div>
												<p>${feedback.noterely || ''}</p>
											</div>`;
								}
							});


							$(".comment_list").html(html);
							initializeThumbnailClickHandler();
								  // Hiển thị phân trang
							renderPagination(response.totalRecords, response.pageSize, response.currentPage, response.fillter, response.productId);
						} else {
							alert(response.message);
						}
					},
					error: function () {
						alert("Lỗi không xác định khi tải dữ liệu.");
					}
				});
			}

			function renderPagination(totalRecords, pageSize, currentPage, fillter,productId) {
				let totalPages = Math.ceil(totalRecords / pageSize);
				let paginationHTML = `<div class="pagination">`;

				// Nút "Trước"
				if (currentPage > 1) {
									paginationHTML += `<a  class="prev-arrow" onclick="loadFeedbacks(${productId},${currentPage - 1},${fillter})">
						<i class="fa fa-long-arrow-left" aria-hidden="true"></i>
					</a>`;
				}

				// Hiển thị số trang
				let maxPagesToShow = 5;
				let startPage = Math.max(1, currentPage - Math.floor(maxPagesToShow / 2));
				let endPage = Math.min(totalPages, startPage + maxPagesToShow - 1);

				if (startPage > 1) {
								paginationHTML += `<a  onclick="loadFeedbacks(${productId},1,${fillter})">1</a>`;
					if (startPage > 2) {
						paginationHTML += `<a  class="dot-dot"><i class="fa fa-ellipsis-h" aria-hidden="true"></i></a>`;
					}
				}

				for (let i = startPage; i <= endPage; i++) {
								paginationHTML += `<a  onclick="loadFeedbacks(${productId},${i},${fillter})" class="${i === currentPage ? "active" : ""}">${i}</a>`;
				}

				if (endPage < totalPages) {
					if (endPage < totalPages - 1) {
						paginationHTML += `<a  class="dot-dot"><i class="fa fa-ellipsis-h" aria-hidden="true"></i></a>`;
					}
								paginationHTML += `<a  onclick="loadFeedbacks(${productId},${totalPages},${fillter})">${totalPages}</a>`;
				}

				// Nút "Sau"
				if (currentPage < totalPages) {
								paginationHTML += `<a  class="next-arrow" onclick="loadFeedbacks(${productId},${currentPage + 1},${fillter})">
						<i class="fa fa-long-arrow-right" aria-hidden="true"></i>
					</a>`;
				}

				paginationHTML += `</div>`;
				$("#pagination").html(paginationHTML);
			}


				// scorll for feedback
				function scrollToElement(elementId) {
				$('html, body').animate({
					scrollTop: $("#" + elementId).offset().top
				}, 800); // 800ms để mượt mà
			}









			function getProductPrice(productId, sizename)
			 {
				$.ajax({
					url: "/Product/GetPrice",
					type: "GET",
					data: { id: productId, sizename: sizename },
					success: function (response)
					{
						if (response.success) {

									if (response.discount==0)
									{

											$("#price_ajax").html(new Intl.NumberFormat('vi-VN').format(response.price) + " ₫");
											$("#tag_wait_ajax").html("");

								}else
								{


									 // Tính toán giá sau khi giảm và định dạng số
										let discountedPrice = response.price - (response.price * response.discount);
										let formattedDiscountedPrice = new Intl.NumberFormat('vi-VN').format(discountedPrice) + " đ";
										let formattedOriginalPrice = new Intl.NumberFormat('vi-VN').format(response.price) + " đ";

										// Gán giá trị vào các phần tử HTML
										$("#price_ajax").html(formattedDiscountedPrice);
										$("#tag_wait_ajax").html("<h4 style='color: gray;'>" + formattedOriginalPrice + "</h4>");

								}

						} else {
							alert("Không tìm thấy giá!");
						}
					},
					error: function ()
					{
						alert("Có lỗi xảy ra, vui lòng thử lại!");
					}
				});
			}


			function initializeThumbnailClickHandler()
			{
			let currentThumbnail = null;
			$('#thumbnailContainer .thumbnail').click(function () {
				let imgSrc = $(this).find('img').attr('src');

				if (currentThumbnail === this) {
					$('#mainImageContainer').collapse('hide');
					currentThumbnail = null;
				} else {
					$('#largeImage').attr('src', imgSrc);
					$('#mainImageContainer').collapse('show');
					currentThumbnail = this;
				}
			});

			$('#mainImageContainer').on('hidden.bs.collapse', function () {
				currentThumbnail = null;
			});
		}



		$(document).ready(initializeThumbnailClickHandler);

	</script>
}

